<ui:FluentWindow x:Class="TeamsStatus.FirmwareUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Firmware wird aktualisiert..." Height="200" Width="400"
        WindowBackdropType="Mica" ExtendsContentIntoTitleBar="True" WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <ui:TitleBar Title="Firmware wird aktualisiert..." Grid.Row="0" Margin="0" ShowMaximize="False" PreviewMouseLeftButtonDown="TitleBar_PreviewMouseLeftButtonDown" />
        
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="300" Margin="20">
            <ui:TextBlock x:Name="TxtStatus" Text="Vorbereitung..." FontTypography="BodyStrong" HorizontalAlignment="Center" Margin="0,0,0,15" TextAlignment="Center" TextWrapping="Wrap"/>
            <ProgressBar x:Name="ProgressDownload" Minimum="0" Maximum="100" Height="20" Margin="0,0,0,10"/>
            <ui:TextBlock x:Name="TxtDetail" Text="0 %" FontTypography="Caption" Appearance="Secondary" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
