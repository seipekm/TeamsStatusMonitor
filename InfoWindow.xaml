<ui:FluentWindow x:Class="TeamsStatus.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Über Teams Status Monitor" SizeToContent="WidthAndHeight"
        WindowBackdropType="Mica" ExtendsContentIntoTitleBar="True" WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False" Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <ui:TitleBar Title="Über Teams Status Monitor" Grid.Row="0" Margin="0" ShowMaximize="False" PreviewMouseLeftButtonDown="TitleBar_PreviewMouseLeftButtonDown" />
        
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
            <ui:TextBlock Text="Teams Status Monitor" FontTypography="Title" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            
            <ui:TextBlock x:Name="TxtVersion" Text="Version: 1.0.0" FontTypography="Body" Appearance="Secondary" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            
            <ui:TextBlock Text="Überträgt den Microsoft Teams Status" FontTypography="Body" Appearance="Secondary" HorizontalAlignment="Center"/>
            <ui:TextBlock Text="an einen per USB angeschlossenen Arduino." FontTypography="Body" Appearance="Secondary" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            
            <TextBlock HorizontalAlignment="Center" Margin="0,0,0,20">
                <Hyperlink RequestNavigate="Hyperlink_RequestNavigate" NavigateUri="https://github.com/seipekm/TeamsStatusMonitor">
                    GitHub Repository besuchen
                </Hyperlink>
            </TextBlock>
            
            <ui:Button Content="Schließen" Icon="{ui:SymbolIcon Dismiss24}" Width="110" Padding="5" Click="BtnClose_Click" HorizontalAlignment="Center" Appearance="Primary"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
