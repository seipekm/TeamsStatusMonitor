<ui:FluentWindow x:Class="TeamsStatus.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Über Teams Status Monitor" SizeToContent="WidthAndHeight"
        WindowBackdropType="Mica" ExtendsContentIntoTitleBar="True" WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Teams Status Monitor" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            
            <TextBlock x:Name="TxtVersion" Text="Version: 1.0.0" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,15" Foreground="#555"/>
            
            <TextBlock Text="Überträgt den Microsoft Teams Status" HorizontalAlignment="Center" Foreground="#333"/>
            <TextBlock Text="an einen per USB angeschlossenen Arduino." HorizontalAlignment="Center" Margin="0,0,0,15" Foreground="#333"/>
            
            <TextBlock HorizontalAlignment="Center" Margin="0,0,0,20">
                <Hyperlink RequestNavigate="Hyperlink_RequestNavigate" NavigateUri="https://github.com/seipekm/TeamsStatusMonitor">
                    GitHub Repository besuchen
                </Hyperlink>
            </TextBlock>
            
            <Button Content="Schließen" Width="100" Padding="5" Click="BtnClose_Click" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
