<ui:FluentWindow x:Class="TeamsStatus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Teams Status Monitor v1.2.26" Width="600" Height="800" Icon="icon.ico"
        WindowBackdropType="Mica" ExtendsContentIntoTitleBar="True" WindowCornerPreference="Round"
        ResizeMode="CanMinimize"
        Closing="Window_Closing">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <tb:TaskbarIcon x:Name="MyNotifyIcon"
                        ToolTipText="Teams Status Monitor"
                        IconSource="pack://application:,,,/icon.ico"
                        TrayMouseDoubleClick="MyNotifyIcon_TrayMouseDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Öffnen" Click="MenuItem_Open_Click" />
                    <Separator />
                    <MenuItem Header="Auf App-Update prüfen" Click="MenuItem_Update_Click" />
                    <MenuItem Header="Auf Firmware-Update prüfen" Click="MenuItem_FirmwareUpdate_Click" />
                    <MenuItem Header="App / Entwickler Info" Click="MenuItem_Info_Click" />
                    <Separator />
                    <MenuItem Header="Beenden" Click="MenuItem_Exit_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <ui:TitleBar x:Name="MainTitleBar" Title="Teams Status Monitor v1.2.26" Grid.Row="0" Margin="0" ShowMaximize="False" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">
                
                <!-- Verbindung -->
                <ui:Card Margin="0,0,0,10">
                    <StackPanel>
                        <ui:TextBlock FontTypography="Subtitle" Text="Verbindung" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="CmbPorts" Grid.Column="0" Margin="0,0,10,0" SelectionChanged="CmbPorts_SelectionChanged" HorizontalAlignment="Stretch"/>
                            <ui:Button Content="Aktualisieren" Grid.Column="1" Margin="0,0,10,0" Click="BtnRefreshPorts_Click"/>
                            <ui:Button x:Name="BtnConnect" Content="Verbinden" Grid.Column="2" Margin="0,0,10,0" Click="BtnConnect_Click" Width="100"/>
                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0,0,0">
                                <Ellipse x:Name="ConnIcon" Width="10" Height="10" Fill="Red" Margin="0,0,5,0" />
                                <TextBlock x:Name="TxtConnStatus" Text="Getrennt" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Status / Effekte -->
                <ui:Card Margin="0,0,0,10">
                    <StackPanel>
                        <ui:TextBlock FontTypography="Subtitle" Text="Status / Effekte" Margin="0,0,0,10"/>
                        <Grid x:Name="GridEffects">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Row 0 -->
                            <ui:Button Content="Aus" Background="#444444" Click="BtnEffect_Click" Tag="0,0,0" Grid.Row="0" Grid.Column="0" Margin="2" HorizontalAlignment="Stretch" Foreground="White" BorderThickness="0"/>
                            <ui:Button Content="Frei" Background="#32CD32" Click="BtnEffect_Click" Tag="50,205,50" Grid.Row="0" Grid.Column="1" Margin="2" HorizontalAlignment="Stretch" Foreground="White" BorderThickness="0"/>
                            <ui:Button Content="Besetzt" Background="#DC143C" Click="BtnEffect_Click" Tag="220,20,60" Grid.Row="0" Grid.Column="2" Margin="2" HorizontalAlignment="Stretch" Foreground="White" BorderThickness="0"/>
                            <ui:Button Content="Anruf" Background="#FF4500" Click="BtnEffect_Click" Tag="255,69,0" Grid.Row="0" Grid.Column="3" Margin="2" HorizontalAlignment="Stretch" Foreground="White" BorderThickness="0"/>
                            <ui:Button Content="Abwesend" Background="#DAA520" Click="BtnEffect_Click" Tag="218,165,32" Grid.Row="0" Grid.Column="4" Margin="2" HorizontalAlignment="Stretch" Foreground="White" BorderThickness="0"/>
                            <ui:Button Content="Blaulicht" Background="#1E90FF" Click="BtnEffect_Click" Tag="Blaulicht" Grid.Row="0" Grid.Column="5" Margin="2" HorizontalAlignment="Stretch" Foreground="White" BorderThickness="0"/>

                            <!-- Row 1 -->
                            <ui:Button Content="Rainbow" Background="#8A2BE2" Click="BtnEffect_Click" Tag="Rainbow" Grid.Row="1" Grid.Column="0" Margin="2" HorizontalAlignment="Stretch" Foreground="White" BorderThickness="0"/>
                            <ui:Button Content="Scan" Background="#4682B4" Click="BtnEffect_Click" Tag="70,130,180" Grid.Row="1" Grid.Column="1" Margin="2" HorizontalAlignment="Stretch" Foreground="White" BorderThickness="0"/>
                            <ui:Button Content="Fire" Background="#D2691E" Click="BtnEffect_Click" Tag="Fire" Grid.Row="1" Grid.Column="2" Margin="2" HorizontalAlignment="Stretch" Foreground="White" BorderThickness="0"/>
                            <ui:Button Content="Teams" Background="#0078D4" Click="BtnEffect_Click" Tag="Auto" Grid.Row="1" Grid.Column="3" Margin="2" HorizontalAlignment="Stretch" Foreground="White" BorderThickness="0"/>
                            <ui:Button Content="Help" Background="#696969" Click="BtnEffect_Click" Tag="255,255,255" Grid.Row="1" Grid.Column="4" Margin="2" HorizontalAlignment="Stretch" Foreground="White" BorderThickness="0"/>
                            <ui:Button Content="Version" Background="#696969" Click="BtnEffect_Click" Tag="VERSION" Grid.Row="1" Grid.Column="5" Margin="2" HorizontalAlignment="Stretch" Foreground="White" BorderThickness="0"/>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Helligkeit -->
                <ui:Card Margin="0,0,0,10">
                    <StackPanel>
                        <ui:TextBlock FontTypography="Subtitle" Text="Helligkeit" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Brightness 0..255" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Slider x:Name="SldBrightness" Grid.Column="1" Minimum="0" Maximum="255" Value="128" ValueChanged="SldBrightness_ValueChanged" VerticalAlignment="Center"/>
                            <ui:TextBlock x:Name="TxtBrightness" Text="128" Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center" Width="30"/>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Start / Automatik -->
                <ui:Card Margin="0,0,0,10">
                    <StackPanel>
                        <ui:TextBlock FontTypography="Subtitle" Text="Start / Automatik" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <CheckBox x:Name="ChkAutoConnect" Content="Automatisch verbinden" Grid.Row="0" Grid.Column="0" Margin="0,0,0,5" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                            <CheckBox x:Name="ChkStartMinimized" Content="Minimiert starten" Grid.Row="1" Grid.Column="0" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                            
                            <CheckBox x:Name="ChkStartWindows" Content="Mit Windows starten" Grid.Row="0" Grid.Column="1" Margin="0,0,0,5" Checked="ChkStartWindows_Changed" Unchecked="ChkStartWindows_Changed"/>
                            <CheckBox x:Name="ChkSendFree" Content="Nach Verbindung 'free' senden" Grid.Row="1" Grid.Column="1" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Teams-Status (Lokale Logs) -->
                <ui:Card Margin="0,0,0,10">
                    <StackPanel>
                        <ui:TextBlock FontTypography="Subtitle" Text="Teams-Status (Lokale Logs)" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <CheckBox x:Name="ChkDebugLog" Content="Debug aktivieren (mehr Output)" Grid.Row="0" Margin="0,0,0,5" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                            <CheckBox x:Name="ChkMonitorStatus" Content="Lokalen Teams-Status überwachen" Grid.Row="1" Margin="0,0,0,10" Checked="ChkMonitorStatus_Changed" Unchecked="ChkMonitorStatus_Changed"/>
                            
                            <ui:Button Content="App / Entwickler Info" Grid.Row="2" HorizontalAlignment="Stretch" Margin="0,0,0,5" Click="MenuItem_Info_Click"/>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Manuelles Kommando -->
                <ui:Card Margin="0,0,0,10">
                    <StackPanel>
                        <ui:TextBlock FontTypography="Subtitle" Text="Manuelles Kommando" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="TxtManualCommand" Grid.Column="0" Margin="0,0,10,0" PlaceholderText="Befehl eingeben..." KeyDown="TxtManualCommand_KeyDown"/>
                            <ui:Button Content="Senden" Grid.Column="1" Click="BtnManualCommand_Click" Width="100"/>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Log -->
                <ui:Card Margin="0,0,0,10">
                    <StackPanel>
                        <ui:TextBlock FontTypography="Subtitle" Text="Log" Margin="0,0,0,10"/>
                        <TextBox x:Name="TxtLogOutput" Height="150" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" FontFamily="Consolas" Background="#1E1E1E" Foreground="#CCCCCC" BorderThickness="0"/>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
