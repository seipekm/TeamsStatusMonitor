<Window x:Class="TeamsStatus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="Teams Status Monitor" SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        Closing="Window_Closing">
    
    <Grid Margin="15">
        <!-- System Tray Icon -->
        <tb:TaskbarIcon x:Name="MyNotifyIcon"
                        ToolTipText="Teams Status Monitor"
                        IconSource="pack://application:,,,/icon.ico"
                        TrayMouseDoubleClick="MyNotifyIcon_TrayMouseDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Öffnen" Click="MenuItem_Open_Click" />
                    <MenuItem Header="Status manuell setzen">
                        <MenuItem x:Name="MenuStatusAuto" Header="Auto (Teams)" Click="MenuItem_StatusAuto_Click" IsCheckable="True" IsChecked="True" />
                        <MenuItem x:Name="MenuStatusAvailable" Header="Verfügbar" Click="MenuItem_StatusAvailable_Click" IsCheckable="True" />
                        <MenuItem x:Name="MenuStatusBusy" Header="Beschäftigt" Click="MenuItem_StatusBusy_Click" IsCheckable="True" />
                        <MenuItem x:Name="MenuStatusAway" Header="Abwesend" Click="MenuItem_StatusAway_Click" IsCheckable="True" />
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Log-Datei öffnen" Click="MenuItem_OpenLog_Click" />
                    <MenuItem Header="Nach Updates suchen..." Click="MenuItem_Update_Click" />
                    <Separator />
                    <MenuItem Header="Beenden" Click="MenuItem_Exit_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <StackPanel>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="100" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="COM Port:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Ellipse x:Name="ConnIcon" Width="10" Height="10" Fill="Red" Margin="10,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtConnStatus" Text="Getrennt" VerticalAlignment="Center" FontSize="11" Foreground="Gray"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox x:Name="CmbPorts" Width="130" SelectionChanged="CmbPorts_SelectionChanged"/>
                        <Button x:Name="BtnConnect" Content="Verbinden" Click="BtnConnect_Click" Margin="10,0,0,0" Width="70"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Baudrate:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CmbBaudRate" SelectionChanged="CmbBaudRate_SelectionChanged">
                        <ComboBoxItem Content="9600" IsSelected="True"/>
                        <ComboBoxItem Content="19200"/>
                        <ComboBoxItem Content="38400"/>
                        <ComboBoxItem Content="57600"/>
                        <ComboBoxItem Content="115200"/>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <TextBlock Text="Helligkeit:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <Slider x:Name="SldBrightness" Width="320" Minimum="0" Maximum="255" Value="128" ValueChanged="SldBrightness_ValueChanged" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtBrightness" Text="128" Margin="10,0,0,0" VerticalAlignment="Center" Width="30"/>
            </StackPanel>

            <TextBlock Text="Modus:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <Button x:Name="BtnModeAuto" Content="Auto (Teams)" Click="BtnMode_Click" Tag="Auto" Padding="8,4" Margin="0,0,5,0" />
                <Button x:Name="BtnModeAvailable" Content="Verfügbar" Click="BtnMode_Click" Tag="A" Padding="8,4" Margin="0,0,5,0" />
                <Button x:Name="BtnModeBusy" Content="Beschäftigt" Click="BtnMode_Click" Tag="B" Padding="8,4" Margin="0,0,5,0" />
                <Button x:Name="BtnModeAway" Content="Abwesend" Click="BtnMode_Click" Tag="W" Padding="8,4" Margin="0,0,5,0" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center">
                <Ellipse x:Name="StatusIcon" Width="16" Height="16" Fill="Gray" Margin="0,0,8,0" Stroke="DarkGray" StrokeThickness="1"/>
                <TextBlock x:Name="TxtStatus" Text="Status: Unbekannt" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Autostart installieren" Click="BtnInstallAutostart_Click" Margin="0,0,10,0" Padding="15,5"/>
                <Button Content="Autostart deinstallieren" Click="BtnUninstallAutostart_Click" Margin="0,0,10,0" Padding="15,5"/>
                <Button Content="Log öffnen" Click="MenuItem_OpenLog_Click" Padding="15,5"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
